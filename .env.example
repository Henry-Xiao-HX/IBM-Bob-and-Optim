# IBM Optim Archive API Configuration
# Copy this file to .env and fill in your credentials

# Required: API Configuration
OPTIM_BASE_URL=https://VM_HOST:7725/optim
OPTIM_USERNAME=your_username
OPTIM_PASSWORD=your_password

# Optional: Only needed for multi-tenant environments
OPTIM_ACCOUNT_ID=

# Required: Database connection profile for Database API
OPTIM_CONN_PROFILE=your_connection_profile

# Optional: Database schema and table configuration for TDM
# Defaults: OPTIM and "TDM - MODIFIED-BY-OPTIM"
OPTIM_SCHEMA_NAME=OPTIM
OPTIM_TABLE_NAME=TDM - MODIFIED-BY-OPTIM

# Optional: Leave empty - token will be auto-fetched and cached
# Only fill this if you want to use a pre-existing token
OPTIM_ACCESS_TOKEN=